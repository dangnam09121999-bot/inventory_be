# Application
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=inventory_db
DB_DATABASE=inventory_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-64-char-random-string
JWT_EXPIRES_IN=7d

# CORS (Frontend URL) - use comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173

# Email Backup Configuration (cron 20:00 giờ VN hàng ngày)
# Ví dụ Gmail: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_USER=you@gmail.com,
# MAIL_PASS=<App Password 16 ký tự>, MAIL_FROM="Inventory <you@gmail.com>", MAIL_TO=admin@example.com
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_TO=
